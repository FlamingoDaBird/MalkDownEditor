{
  "name": "md-editor",
  "displayName": "MalkDown Editor",
  "description": "WYSIWYG Markdown editor for VS Code using Milkdown Crepe.",
  "version": "0.1.3",
  "icon": "media/icon.png",
  "publisher": "flamingo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/FlamingoDaBird/MalkDownEditor.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "milkdown"
  ],
  "activationEvents": [
    "onCustomEditor:mdeditor.markdownEditor",
    "onCommand:mdeditor.open",
    "onCommand:mdeditor.insertDate",
    "onCommand:mdeditor.insertTime",
    "onCommand:mdeditor.insertDateTime",
    "onCommand:mdeditor.insertLastUpdated",
    "onCommand:mdeditor.updateLastUpdated",
    "onCommand:mdeditor.insertHistoryEntry",
    "onCommand:mdeditor.insertCustomDateTime",
    "onCommand:mdeditor.openSettings",
    "onCommand:mdeditor.toggleReadOnly",
    "onCommand:mdeditor.enableReadOnly",
    "onCommand:mdeditor.disableReadOnly"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mdeditor.open",
        "title": "MalkDown Editor",
        "category": "MalkDown Editor",
        "icon": {
          "light": "media/editor-title-icon-dark.svg",
          "dark": "media/editor-title-icon-light.svg"
        }
      },
      {
        "command": "mdeditor.insertDate",
        "title": "Insert Today's Date",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.insertTime",
        "title": "Insert Current Time",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.insertDateTime",
        "title": "Insert Date and Time",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.insertLastUpdated",
        "title": "Insert Last Updated",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.updateLastUpdated",
        "title": "Update Last Updated Line",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.insertHistoryEntry",
        "title": "Insert History Entry",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.insertCustomDateTime",
        "title": "Insert Custom Date/Time Snippet",
        "category": "MalkDown Editor"
      },
      {
        "command": "mdeditor.openSettings",
        "title": "Open Settings",
        "category": "MalkDown Editor",
        "icon": "$(gear)"
      },
      {
        "command": "mdeditor.toggleReadOnly",
        "title": "Toggle Read-Only Mode",
        "category": "MalkDown Editor",
        "icon": "$(lock)"
      },
      {
        "command": "mdeditor.enableReadOnly",
        "title": "Enable Read-Only Mode",
        "category": "MalkDown Editor",
        "icon": "$(unlock)"
      },
      {
        "command": "mdeditor.disableReadOnly",
        "title": "Disable Read-Only Mode",
        "category": "MalkDown Editor",
        "icon": "$(lock)"
      }
    ],
    "configuration": [
      {
        "title": "MalkDown Editor: Appearance",
        "order": 10,
        "properties": {
          "mdEditor.theme": {
            "type": "string",
            "enum": [
              "vscode-dark",
              "vscode-light",
              "vscode-high-contrast",
              "default"
            ],
            "enumItemLabels": [
              "VS Code Dark",
              "VS Code Light",
              "VS Code High Contrast",
              "Default"
            ],
            "markdownEnumDescriptions": [
              "Use the dark webview theme.",
              "Use the light webview theme.",
              "Use the high-contrast webview theme.",
              "Use MalkDown Editor's default theme selection."
            ],
            "default": "vscode-dark",
            "order": 10,
            "markdownDescription": "Theme used by the MalkDown Editor webview."
          }
        }
      },
      {
        "title": "MalkDown Editor: Attachments",
        "order": 20,
        "properties": {
          "mdEditor.attachments.locationMode": {
            "type": "string",
            "enum": [
              "markdown-folder-attachments",
              "markdown-folder",
              "workspace-relative-path",
              "ask-each-time"
            ],
            "enumItemLabels": [
              "Markdown Folder Attachments",
              "Markdown Folder",
              "Workspace Relative Path",
              "Ask Each Time"
            ],
            "markdownEnumDescriptions": [
              "Save into a `.attachments` folder next to the Markdown file.",
              "Save directly beside the Markdown file.",
              "Save into a workspace-root relative folder.",
              "Ask for a folder each time an attachment is uploaded."
            ],
            "default": "markdown-folder-attachments",
            "order": 10,
            "markdownDescription": "Where MalkDown Editor saves uploaded attachments."
          },
          "mdEditor.attachments.folderName": {
            "type": "string",
            "default": ".attachments",
            "order": 20,
            "markdownDescription": "Folder name created beside the current Markdown file.\n\nOnly used when [Location Mode](#mdEditor.attachments.locationMode#) is `markdown-folder-attachments`."
          },
          "mdEditor.attachments.path": {
            "type": "string",
            "default": "attachments",
            "order": 30,
            "markdownDescription": "Workspace-relative folder for attachments.\n\nOnly used when [Location Mode](#mdEditor.attachments.locationMode#) is `workspace-relative-path`. Do not use an absolute path like `/home/name/...`."
          },
          "mdEditor.attachments.alwaysUseOriginalFilename": {
            "type": "boolean",
            "default": false,
            "order": 40,
            "markdownDescription": "Use the uploaded file's original filename when saving attachments. Existing files are never overwritten."
          },
          "mdEditor.attachments.alwaysConfirmNameAndPath": {
            "type": "boolean",
            "default": false,
            "order": 50,
            "markdownDescription": "Ask for the attachment folder and filename before every attachment is saved."
          },
          "mdEditor.attachments.generatedNameDigits": {
            "type": "number",
            "default": 9,
            "minimum": 1,
            "maximum": 18,
            "order": 60,
            "markdownDescription": "Number of digits in generated attachment filenames, for example `features-000000001.png`."
          },
          "mdEditor.attachments.askBeforeDeletingFiles": {
            "type": "boolean",
            "default": true,
            "order": 70,
            "markdownDescription": "Ask before deleting a local attachment file from disk when its attachment reference is removed from MalkDown Editor. The safe default action is `Cancel`."
          },
          "mdEditor.attachments.trash.enabled": {
            "type": "boolean",
            "default": true,
            "order": 80,
            "markdownDescription": "Show a recoverable `Move to Trash` option when a local attachment reference is removed from MalkDown Editor."
          },
          "mdEditor.attachments.trash.folderName": {
            "type": "string",
            "default": ".attachments-trash",
            "order": 90,
            "markdownDescription": "Workspace-root relative folder where MalkDown Editor moves trashed attachments.\n\nDefault: `.attachments-trash`, which creates one master trash folder in the current workspace root."
          },
          "mdEditor.attachments.trash.preserveOriginalPath": {
            "type": "boolean",
            "default": true,
            "order": 100,
            "markdownDescription": "Preserve the attachment's original workspace-relative folder path inside the attachment trash folder."
          },
          "mdEditor.attachments.trash.writeIndex": {
            "type": "boolean",
            "default": true,
            "order": 110,
            "markdownDescription": "Write `.attachments-trash/index.json` entries when attachments are moved to the attachment trash."
          }
        }
      },
      {
        "title": "MalkDown Editor: Tables",
        "order": 30,
        "properties": {
          "mdEditor.tables.floatingToolbar": {
            "type": "boolean",
            "default": true,
            "order": 10,
            "markdownDescription": "Show MalkDown Editor's floating table toolbar when the cursor is inside a table."
          },
          "mdEditor.tables.contextMenu": {
            "type": "boolean",
            "default": true,
            "order": 20,
            "markdownDescription": "Enable MalkDown Editor's right-click table action menu."
          },
          "mdEditor.tables.milkdownControls": {
            "type": "boolean",
            "default": true,
            "order": 30,
            "markdownDescription": "Show the built-in Milkdown table handles and grid-line add controls."
          },
          "mdEditor.tables.slashMenu": {
            "type": "boolean",
            "default": true,
            "order": 40,
            "markdownDescription": "Enable MalkDown Editor's table-cell slash menu. Type `/` as the first character in a table cell to add/delete rows or columns."
          },
          "mdEditor.tables.defaultRows": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "maximum": 50,
            "order": 50,
            "markdownDescription": "Default number of rows used when inserting a new GFM Markdown table."
          },
          "mdEditor.tables.defaultColumns": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "maximum": 20,
            "order": 60,
            "markdownDescription": "Default number of columns used when inserting a new GFM Markdown table."
          },
          "mdEditor.tables.insertBehavior": {
            "type": "string",
            "enum": [
              "useDefaultSize",
              "askEveryTime"
            ],
            "enumItemLabels": [
              "Use Default Size",
              "Ask Every Time"
            ],
            "markdownEnumDescriptions": [
              "Insert a table immediately using the configured default rows and columns.",
              "Open a row/column picker every time Insert Table is selected."
            ],
            "default": "useDefaultSize",
            "order": 70,
            "markdownDescription": "Controls whether Insert Table uses the configured default size or asks for rows and columns each time."
          }
        }
      },
      {
        "title": "MalkDown Editor: Code Blocks",
        "order": 40,
        "properties": {
          "mdEditor.codeBlocks.alwaysShowLanguage": {
            "type": "boolean",
            "default": false,
            "order": 10,
            "markdownDescription": "Always show the selected language label on code blocks instead of only showing it on hover."
          },
          "mdEditor.codeBlocks.alwaysShowCopyButton": {
            "type": "boolean",
            "default": false,
            "order": 20,
            "markdownDescription": "Always show the code block Copy button instead of only showing it on hover."
          }
        }
      },
      {
        "title": "MalkDown Editor: Date & Time",
        "order": 50,
        "properties": {
          "mdEditor.dateTime.dateFormat": {
            "type": "string",
            "default": "yyyy-MM-dd",
            "order": 10,
            "markdownDescription": "Date format used by MalkDown Editor timestamp tools. Supported tokens include `yyyy`, `yy`, `MM`, `M`, `dd`, and `d`."
          },
          "mdEditor.dateTime.timeFormat": {
            "type": "string",
            "default": "HH:mm",
            "order": 20,
            "markdownDescription": "Time format used by MalkDown Editor timestamp tools. Supported tokens include `HH`, `H`, `hh`, `h`, `mm`, `ss`, and `a` for AM/PM."
          },
          "mdEditor.dateTime.lastUpdatedTemplate": {
            "type": "string",
            "default": "Last updated: {date} {time}",
            "editPresentation": "multilineText",
            "order": 30,
            "markdownDescription": "Template inserted or updated by the Last Updated timestamp actions. Available placeholders: `{date}`, `{time}`, `{datetime}`."
          },
          "mdEditor.dateTime.historyEntryTemplate": {
            "type": "string",
            "default": "- {date} {time} - ",
            "editPresentation": "multilineText",
            "order": 40,
            "markdownDescription": "Template inserted by the history entry timestamp action. Available placeholders: `{date}`, `{time}`, `{datetime}`."
          },
          "mdEditor.dateTime.customTemplate": {
            "type": "string",
            "default": "{date} {time}",
            "editPresentation": "multilineText",
            "order": 50,
            "markdownDescription": "Template inserted by the custom date/time snippet action. Available placeholders: `{date}`, `{time}`, `{datetime}`."
          },
          "mdEditor.dateTime.inlineSlashShortcuts": {
            "type": "boolean",
            "default": true,
            "order": 60,
            "markdownDescription": "Enable lightweight inline date/time shortcuts such as `/date`, `/time`, `/datetime`, `/updated`, and `/history`. Shortcuts are replaced only when accepted with `Tab` or `Enter` and are ignored inside URLs, paths, and words."
          }
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "mdeditor.markdownEditor",
        "displayName": "MalkDown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mdeditor.open",
          "when": "resourceExtname == .md",
          "group": "navigation@10"
        },
        {
          "command": "mdeditor.openSettings",
          "when": "activeCustomEditorId == 'mdeditor.markdownEditor'",
          "group": "navigation@11"
        },
        {
          "command": "mdeditor.enableReadOnly",
          "when": "activeCustomEditorId == 'mdeditor.markdownEditor' && !mdeditor.readOnly",
          "group": "navigation@12"
        },
        {
          "command": "mdeditor.disableReadOnly",
          "when": "activeCustomEditorId == 'mdeditor.markdownEditor' && mdeditor.readOnly",
          "group": "navigation@12"
        }
      ],
      "editor/title/context": [
        {
          "command": "mdeditor.enableReadOnly",
          "when": "resourceExtname == .md && !mdeditor.readOnly",
          "group": "navigation@19"
        },
        {
          "command": "mdeditor.disableReadOnly",
          "when": "resourceExtname == .md && mdeditor.readOnly",
          "group": "navigation@19"
        },
        {
          "command": "mdeditor.openSettings",
          "when": "resourceExtname == .md",
          "group": "navigation@20"
        }
      ],
      "commandPalette": [
        {
          "command": "mdeditor.open",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertDate",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertTime",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertDateTime",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertLastUpdated",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.updateLastUpdated",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertHistoryEntry",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.insertCustomDateTime",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.openSettings",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.toggleReadOnly",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdeditor.enableReadOnly",
          "when": "resourceExtname == .md && !mdeditor.readOnly"
        },
        {
          "command": "mdeditor.disableReadOnly",
          "when": "resourceExtname == .md && mdeditor.readOnly"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "npm run test:unit && npm run test:security",
    "test:unit": "node --test --test-reporter=spec tests/unit/*.test.mjs",
    "test:security": "node --test --test-reporter=spec tests/security/*.test.mjs",
    "test:watch": "node --test --watch tests/unit/*.test.mjs",
    "verify": "npm run typecheck && npm run build && npm run test:unit && npm run test:security",
    "test:ci": "npm run verify",
    "package:vsix": "mkdir -p artifacts && npx --yes @vscode/vsce package --out artifacts/md-editor-$(node -p \"require('./package.json').version\").vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@milkdown/crepe": "^7.20.0",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "mermaid": "^11.15.0",
    "typescript": "^5.8.3"
  }
}
